local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local CoreGui = game:GetService("CoreGui")

-- 1. Hệ thống thông báo & Khôi phục
local function Notify(title, text)
    StarterGui:SetCore("SendNotification", {
        Title = title,
        Text = text,
        Duration = 2
    })
end

local originalProperties = { Materials = {}, Transparencies = {} }
local connections = { map = nil, dame = nil }

-- 2. Khởi tạo Giao diện
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "V60_Pro_Optimization"
local p = pcall(function() ScreenGui.Parent = CoreGui end)
if not p then ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui") end

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 200, 0, 250)
MainFrame.Position = UDim2.new(0.05, 0, 0.3, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 2
MainFrame.ZIndex = 100
MainFrame.Active = true
MainFrame.Draggable = true

local Layout = Instance.new("UIListLayout", MainFrame)
Layout.Padding = UDim.new(0, 5)
Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

-- 3. BỘ ĐẾM FPS (Cập nhật theo giây)
local FPSLabel = Instance.new("TextLabel", MainFrame)
FPSLabel.Size = UDim2.new(1, 0, 0, 40)
FPSLabel.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
FPSLabel.TextColor3 = Color3.new(0, 1, 0)
FPSLabel.TextSize = 18
FPSLabel.Font = Enum.Font.Code
FPSLabel.Text = "FPS: ..."
FPSLabel.ZIndex = 101

local lastUpdate = tick()
local frameCount = 0
RunService.RenderStepped:Connect(function()
    frameCount = frameCount + 1
    if tick() - lastUpdate >= 1 then
        FPSLabel.Text = "FPS: " .. frameCount
        frameCount = 0
        lastUpdate = tick()
    end
end)

-- 4. Hàm tạo nút bấm (Hỗ trợ Auto-Start)
local function CreateButton(text, autoStart, callback)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Text = text
    btn.BackgroundColor3 = autoStart and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(60, 60, 60)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    btn.ZIndex = 101
    
    local active = autoStart
    local function Toggle(state)
        active = state
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(60, 60, 60)
        task.spawn(function() callback(active) end)
    end

    btn.MouseButton1Click:Connect(function()
        Toggle(not active)
    end)
    
    if autoStart then task.spawn(function() callback(true) end) end
end

-- Mở khóa 120 FPS
if setfpscap then setfpscap(120) end

-- Nút 1: Boost FPS (Auto)
CreateButton("Boost FPS 120", true, function(state)
    if state then
        Lighting.GlobalShadows = false
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") then
                if not originalProperties.Materials[v] then originalProperties.Materials[v] = v.Material end
                v.Material = Enum.Material.SmoothPlastic
            elseif v:IsA("Decal") or v:IsA("Texture") then
                if not originalProperties.Transparencies[v] then originalProperties.Transparencies[v] = v.Transparency end
                v.Transparency = 1
            end
        end
        Notify("FPS Boost", "Đã bật tối ưu mượt nhất.")
    else
        for part, mat in pairs(originalProperties.Materials) do
            if part and part.Parent then part.Material = mat end
        end
        Notify("FPS Boost", "Đã khôi phục đồ họa.")
    end
end)

-- Nút 2: Mờ Map (Auto - Tối ưu mới)
CreateButton("Làm Mờ Map", true, function(state)
    if state then
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then v.Transparency = 0.9 end
        end
        connections.map = Workspace.DescendantAdded:Connect(function(v)
            if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then v.Transparency = 0.9 end
        end)
        Notify("Map", "Đã làm mờ cảnh vật.")
    else
        if connections.map then connections.map:Disconnect() end
        Notify("Map", "Đã khôi phục độ mờ.")
    end
end)

-- Nút 3: Xóa Dame Nổi (Auto - Tối ưu mới)
CreateButton("Xóa Dame Nổi", true, function(state)
    if state then
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BillboardGui") and (v.Name:lower():find("damage") or v.Name:lower():find("dame")) then v.Enabled = false end
        end
        connections.dame = Workspace.DescendantAdded:Connect(function(v)
            if v:IsA("BillboardGui") and (v.Name:lower():find("damage") or v.Name:lower():find("dame")) then v.Enabled = false end
        end)
        Notify("Dame", "Đã xóa sát thương nổi.")
    else
        if connections.dame then connections.dame:Disconnect() end
        Notify("Dame", "Đã hiện lại sát thương nổi.")
    end
end)

-- Nút 4: Black Screen (Off)
local blackFrame = nil
CreateButton("Black Screen", true, function(state)
    if state then
        if not blackFrame then
            blackFrame = Instance.new("Frame", ScreenGui)
            blackFrame.Size = UDim2.new(10, 0, 10, 0)
            blackFrame.Position = UDim2.new(-5, 0, -5, 0)
            blackFrame.BackgroundColor3 = Color3.new(0, 0, 0)
            blackFrame.ZIndex = 50
        end
        blackFrame.Visible = true
        Notify("AFK", "Màn hình đen bật.")
    else
        if blackFrame then blackFrame.Visible = false end
        Notify("AFK", "Màn hình đen tắt.")
    end
end)

Notify("V60 Pro", "Đã tự động kích hoạt tối ưu!")
