-- Các biến trạng thái và lưu trữ để khôi phục (Revert)
local originalData = { Materials = {}, Transparencies = {}, Effects = {} }
local states = { FPS = false, Map = false, Black = false }

-- 1. Hàm SIÊU FIX LAG (Render tối thiểu)
local function ToggleUltraFPS(state)
    if state then
        settings().Rendering.QualityLevel = 1
        Lighting.GlobalShadows = false
        Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
        
        for _, v in pairs(Lighting:GetDescendants()) do
            if v:IsA("PostEffect") or v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") then
                originalData.Effects[v] = v.Enabled
                v.Enabled = false
            end
        end
        
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") then
                originalData.Materials[v] = v.Material
                v.Material = Enum.Material.SmoothPlastic
            end
        end
        Notify("Optimization", "Đã bật SIÊU TỐI ƯU (Max FPS).")
    else
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        Lighting.GlobalShadows = true
        for effect, enabled in pairs(originalData.Effects) do
            if effect then effect.Enabled = enabled end
        end
        for part, material in pairs(originalData.Materials) do
            if part and part.Parent then part.Material = material end
        end
        originalData.Materials = {}
        Notify("Optimization", "Đã khôi phục chất lượng Render.")
    end
end

-- 2. Quét mờ Map 2s/lần (Giữ va chạm)
local mapLoop = nil
local function ToggleMapBlur(state)
    if state then
        mapLoop = task.spawn(function()
            while true do
                for _, v in pairs(Workspace:GetDescendants()) do
                    if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then
                        if not originalData.Transparencies[v] then
                            originalData.Transparencies[v] = v.Transparency
                        end
                        v.Transparency = 0.9
                    end
                end
                task.wait(2) -- Quét lại mỗi 2 giây
            end
        end)
        Notify("Map Scan", "Đã bật quét mờ map 2s/lần.")
    else
        if mapLoop then task.cancel(mapLoop) end
        for part, trans in pairs(originalData.Transparencies) do
            if part and part.Parent then part.Transparency = trans end
        end
        originalData.Transparencies = {}
        Notify("Map Scan", "Đã dừng quét map.")
    end
end

-- 3. Black Screen (Menu vẫn hiện)
local blackFrame = nil
local function ToggleBlackScreen(state)
    if state then
        if not blackFrame then
            blackFrame = Instance.new("Frame", ScreenGui)
            blackFrame.Size = UDim2.new(10, 0, 10, 0)
            blackFrame.Position = UDim2.new(-5, 0, -5, 0)
            blackFrame.BackgroundColor3 = Color3.new(0, 0, 0)
            blackFrame.ZIndex = 50 -- Thấp hơn MainFrame (100)
        end
        blackFrame.Visible = true
        Notify("Black Screen", "Đã bật màn hình đen (Tiết kiệm pin).")
    else
        if blackFrame then blackFrame.Visible = false end
        Notify("Black Screen", "Đã tắt màn hình đen.")
    end
end

-- Hàm tạo nút
local function CreateButton(text, callback)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    btn.ZIndex = 101
    
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(60, 60, 60)
        callback(active)
    end)
end

-- Thêm các nút chức năng
CreateButton("Siêu Fix Lag (Max)", ToggleUltraFPS)
CreateButton("Quét Mờ Map (2s)", ToggleMapBlur)
CreateButton("Black Screen (AFK)", ToggleBlackScreen)

