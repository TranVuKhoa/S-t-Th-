local deathCount = 0 
local lastPosition = Vector3.new(0, 0, 0)

-- HÀM SERVER HOP NÂNG CẤP (CHỐNG QUAY LẠI SERVER CŨ)
local function ServerHop()
    DeathLabel.Text = "Đang tìm Server mới..."
    DeathLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    
    local PlaceId = game.PlaceId
    local currentJobId = game.JobId
    local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
    
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    
    if success and result and result.data then
        local targetServers = {}
        for _, s in pairs(result.data) do
            -- Lọc: Không phải server này, còn chỗ trống, và có trên 5 người chơi
            if s.id ~= currentJobId and s.playing < s.maxPlayers - 1 and s.playing > 5 then
                table.insert(targetServers, s.id)
            end
        end
        
        if #targetServers > 0 then
            local randomServer = targetServers[math.random(1, #targetServers)]
            TeleportService:TeleportToPlaceInstance(PlaceId, randomServer, Player)
        else
            -- Nếu không tìm thấy server lý tưởng, ép buộc nhảy đại
            TeleportService:Teleport(PlaceId, Player)
        end
    else
        TeleportService:Teleport(PlaceId, Player)
    end
end

-- HÀM DI CHUYỂN MENU
local dragging, dragInput, dragStart, startPos
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = Frame.Position
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
    end
end)
Frame.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- CẬP NHẬT TRẠNG THÁI & REVERT STATE
local function updateVisuals()
    if isEnabled then
        ToggleButton.Text = "TRẠNG THÁI: BẬT"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
    else
        ToggleButton.Text = "TRẠNG THÁI: TẮT"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
        StatusLabel.Text = "Đang tạm dừng"
        -- Revert: Đưa các thông số về ban đầu khi tắt
        idleTime = 0
        deathCount = 0
        DeathLabel.Text = "Lần chết liên tục: 0/3"
    end
end

updateVisuals()

ToggleButton.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    updateVisuals()
end)

-- VÒNG LẶP KIỂM TRA ĐỨNG IM
task.spawn(function()
    while true do
        task.wait(1)
        if Character and Character:FindFirstChild("HumanoidRootPart") and isEnabled then
            local root = Character.HumanoidRootPart
            local currentPos = root.Position
            
            if (currentPos - lastPosition).Magnitude < 0.5 then
                idleTime = idleTime + 1
            else
                idleTime = 0
            end
            
            lastPosition = currentPos
            StatusLabel.Text = "Đứng im: " .. idleTime .. "s / " .. maxIdle .. "s"
            
            if idleTime >= maxIdle then
                local hum = Character:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum.Health = 0 -- Tự reset
                end
                idleTime = 0
            end
        end
    end
end)

-- XỬ LÝ KHI CHẾT LIÊN TỤC
Player.CharacterAdded:Connect(function(newChar)
    Character = newChar
    idleTime = 0
    
    local hum = newChar:WaitForChild("Humanoid")
    hum.Died:Connect(function()
        if isEnabled then
            deathCount = deathCount + 1
            DeathLabel.Text = "Lần chết liên tục: " .. deathCount .. "/3"
            
            if deathCount >= 3 then
                ServerHop()
            end
        end
    end)
end)

-- Reset bộ đếm lần chết nếu người chơi di chuyển thoát khỏi vùng farm
task.spawn(function()
    while true do
        task.wait(5)
        if Character and Character:FindFirstChild("HumanoidRootPart") and isEnabled then
            local root = Character.HumanoidRootPart
            -- Nếu trong 5 giây di chuyển được > 50 studs, coi như không bị farm
            if (root.Position - lastPosition).Magnitude > 50 then
                deathCount = 0
                DeathLabel.Text = "Lần chết liên tục: 0/3"
            end
        end
    end
end)
