-- HÀM SERVER HOP (Giữ nguyên của bạn)
local function ServerHop()
    DeathLabel.Text = "Đang tìm Server..."
    DeathLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    
    local PlaceId = game.PlaceId
    local currentJobId = game.JobId
    local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
    
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    
    if success and result and result.data then
        local targetServers = {}
        for _, s in pairs(result.data) do
            if s.id ~= currentJobId and s.playing < s.maxPlayers then
                if s.playing >= 5 and s.playing <= 9 then
                    table.insert(targetServers, s.id)
                end
            end
        end
        
        if #targetServers > 0 then
            TeleportService:TeleportToPlaceInstance(PlaceId, targetServers[math.random(1, #targetServers)], Player)
        else
            TeleportService:Teleport(PlaceId, Player)
        end
    else
        TeleportService:Teleport(PlaceId, Player)
    end
end

-- DI CHUYỂN GUI (Hỗ trợ kéo thả)
local dragging, dragInput, dragStart, startPos
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = Frame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

