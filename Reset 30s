-- HÀM SERVER HOP (TÌM SERVER 7 NGƯỜI)
local function ServerHop()
    DeathLabel.Text = "Đang tìm Server 7 người..."
    DeathLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    
    local PlaceId = game.PlaceId
    local currentJobId = game.JobId
    -- Lấy danh sách server (ưu tiên số lượng người chơi giảm dần)
    local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
    
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    
    if success and result and result.data then
        local exact7 = {}
        local near7 = {}

        for _, s in pairs(result.data) do
            -- Chỉ xét server khác server hiện tại và còn chỗ
            if s.id ~= currentJobId and s.playing < s.maxPlayers then
                if s.playing == 7 then
                    table.insert(exact7, s.id)
                elseif s.playing >= 5 and s.playing <= 9 then
                    table.insert(near7, s.id)
                end
            end
        end
        
        -- Ưu tiên 1: Server có đúng 7 người
        if #exact7 > 0 then
            TeleportService:TeleportToPlaceInstance(PlaceId, exact7[math.random(1, #exact7)], Player)
        -- Ưu tiên 2: Server từ 5-9 người
        elseif #near7 > 0 then
            TeleportService:TeleportToPlaceInstance(PlaceId, near7[math.random(1, #near7)], Player)
        else
            -- Nếu không tìm thấy, tự động nhảy server bất kỳ
            TeleportService:Teleport(PlaceId, Player)
        end
    else
        TeleportService:Teleport(PlaceId, Player)
    end
end

-- DI CHUYỂN GUI
local dragging, dragInput, dragStart, startPos
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = Frame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- CẬP NHẬT TRẠNG THÁI & RESET DỮ LIỆU
local function updateVisuals()
    if isEnabled then
        ToggleButton.Text = "TRẠNG THÁI: BẬT"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
    else
        ToggleButton.Text = "TRẠNG THÁI: TẮT"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
        StatusLabel.Text = "Đang tạm dừng"
        idleTime = 0
        deathCount = 0
        DeathLabel.Text = "Lần chết liên tục: 0/3"
    end
end

updateVisuals()
ToggleButton.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    updateVisuals()
end)

-- KIỂM TRA ĐỨNG IM
task.spawn(function()
    while true do
        task.wait(1)
        if Character and Character:FindFirstChild("HumanoidRootPart") and isEnabled then
            local currentPos = Character.HumanoidRootPart.Position
            if (currentPos - lastPosition).Magnitude < 0.5 then
                idleTime = idleTime + 1
            else
                idleTime = 0
            end
            lastPosition = currentPos
            StatusLabel.Text = "Đứng im: " .. idleTime .. "s / " .. maxIdle .. "s"
            
            if idleTime >= maxIdle then
                local hum = Character:FindFirstChildOfClass("Humanoid")
                if hum then hum.Health = 0 end
                idleTime = 0
            end
        end
    end
end)

-- XỬ LÝ KHI CHẾT/HỒI SINH
Player.CharacterAdded:Connect(function(newChar)
    Character = newChar
    local hum = newChar:WaitForChild("Humanoid")
    hum.Died:Connect(function()
        if isEnabled then
            deathCount = deathCount + 1
            DeathLabel.Text = "Lần chết liên tục: " .. deathCount .. "/3"
            if deathCount >= 3 then ServerHop() end
        end
    end)
end)
