-- BIẾN ĐIỀU KHIỂN
local isEnabled = true 
local idleTime = 0
local maxIdle = 50
local deathCount = 0 -- Bộ đếm số lần chết
local lastPosition = Vector3.new(0, 0, 0)

-- HÀM SERVER HOP (TÌM SERVER ĐÔNG NGƯỜI)
local function ServerHop()
    print("Thông báo: Đang tìm Server đông người để Hop...")
    local PlaceId = game.PlaceId
    local Servers = {}
    local url = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
    
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    
    if success and result and result.data then
        for _, s in pairs(result.data) do
            -- Chọn server có nhiều người nhưng chưa full (chừa 2 chỗ trống)
            if s.playing < s.maxPlayers and s.playing > 10 and s.id ~= game.JobId then
                table.insert(Servers, s.id)
            end
        end
    end
    
    if #Servers > 0 then
        TeleportService:TeleportToPlaceInstance(PlaceId, Servers[math.random(1, #Servers)], Player)
    else
        print("Không tìm thấy server phù hợp, đang thử lại...")
        TeleportService:Teleport(PlaceId, Player) -- Cứ nhảy server đại
    end
end

-- HÀM DI CHUYỂN MENU
local dragging, dragInput, dragStart, startPos
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = Frame.Position
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
    end
end)
Frame.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- CẬP NHẬT TRẠNG THÁI
local function updateVisuals()
    if isEnabled then
        ToggleButton.Text = "TRẠNG THÁI: BẬT"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
        print("Hệ thống: BẬT.")
    else
        ToggleButton.Text = "TRẠNG THÁI: TẮT"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
        StatusLabel.Text = "Đang tạm dừng"
        print("Hệ thống: TẮT.")
    end
end

updateVisuals()

ToggleButton.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    idleTime = 0
    updateVisuals()
end)

-- VÒNG LẶP KIỂM TRA ĐỨNG IM
task.spawn(function()
    while true do
        task.wait(1)
        local root = Character:FindFirstChild("HumanoidRootPart")
        if root and isEnabled then
            local currentPos = root.Position
            if (currentPos - lastPosition).Magnitude < 0.2 then
                idleTime = idleTime + 1
            else
                idleTime = 0
            end
            lastPosition = currentPos
            StatusLabel.Text = "Đứng im: " .. idleTime .. "s / " .. maxIdle .. "s"
            
            if idleTime >= maxIdle then
                local hum = Character:FindFirstChildOfClass("Humanoid")
                if hum then
                    print("Thông báo: Tự động Reset do đứng im.")
                    hum.Health = 0
                end
                idleTime = 0
            end
        end
    end
end)

-- XỬ LÝ KHI CHẾT LIÊN TỤC
Player.CharacterAdded:Connect(function(newChar)
    Character = newChar
    idleTime = 0
    lastPosition = Vector3.new(0,0,0)
    
    local hum = newChar:WaitForChild("Humanoid")
    hum.Died:Connect(function()
        if isEnabled then
            deathCount = deathCount + 1
            DeathLabel.Text = "Lần chết liên tục: " .. deathCount .. "/3"
            
            if deathCount >= 3 then
                DeathLabel.Text = "Đang đổi Server..."
                task.wait(1)
                ServerHop()
            end
        end
    end)
end)

-- Reset bộ đếm lần chết nếu di chuyển được xa (chứng tỏ không bị farm chết tại chỗ)
task.spawn(function()
    while true do
        task.wait(5)
        local root = Character:FindFirstChild("HumanoidRootPart")
        if root and isEnabled then
            -- Nếu di chuyển được một khoảng cách nhất định, reset bộ đếm lần chết
            if (root.Position - lastPosition).Magnitude > 50 then
                deathCount = 0
                DeathLabel.Text = "Lần chết liên tục: 0/3"
            end
        end
    end
end)
