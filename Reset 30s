local Player = game:GetService("Players").LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local UserInputService = game:GetService("UserInputService")

-- Cấu hình GUI (Nhỏ gọn hơn)
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "MiniResetMenu"
ScreenGui.ResetOnSpawn = false 
ScreenGui.Parent = Player:WaitForChild("PlayerGui")

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 150, 0, 70) -- Kích thước nhỏ lại
Frame.Position = UDim2.new(0.8, 0, 0.1, 0)
Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Frame.BorderSizePixel = 0
Frame.Active = true -- Cho phép tương tác để di chuyển
Frame.Parent = ScreenGui

-- Bo góc cho Menu
local Corner = Instance.new("UICorner")
Corner.CornerRadius = UDim.new(0, 8)
Corner.Parent = Frame

local StatusLabel = Instance.new("TextLabel")
StatusLabel.Size = UDim2.new(1, 0, 0, 30)
StatusLabel.Position = UDim2.new(0, 0, 0, 5)
StatusLabel.Text = "Đứng im: 0s / 30s"
StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
StatusLabel.BackgroundTransparency = 1
StatusLabel.TextSize = 12
StatusLabel.Font = Enum.Font.SourceSansBold
StatusLabel.Parent = Frame

local ToggleButton = Instance.new("TextButton")
ToggleButton.Size = UDim2.new(0.9, 0, 0, 25)
ToggleButton.Position = UDim2.new(0.05, 0, 0, 35)
ToggleButton.TextSize = 12
ToggleButton.Font = Enum.Font.SourceSans
ToggleButton.Parent = Frame

local BtnCorner = Instance.new("UICorner")
BtnCorner.CornerRadius = UDim.new(0, 5)
BtnCorner.Parent = ToggleButton

-- BIẾN ĐIỀU KHIỂN
local isEnabled = true 
local idleTime = 0
local maxIdle = 50
local lastPosition = Vector3.new(0, 0, 0)

-- HÀM DI CHUYỂN MENU (DRAGGABLE)
local dragging, dragInput, dragStart, startPos
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)
Frame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- HÀM CẬP NHẬT TRẠNG THÁI
local function updateVisuals()
    if isEnabled then
        ToggleButton.Text = "TRẠNG THÁI: BẬT"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
        print("Thông báo: Hệ thống Reset tự động đã được KÍCH HOẠT.")
    else
        ToggleButton.Text = "TRẠNG THÁI: TẮT"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
        StatusLabel.Text = "Đang tạm dừng"
        print("Thông báo: Hệ thống Reset tự động đã BỊ VÔ HIỆU HÓA.")
    end
end

updateVisuals()

ToggleButton.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    idleTime = 0
    updateVisuals()
end)

-- VÒNG LẶP KIỂM TRA
task.spawn(function()
    while true do
        task.wait(1)
        local root = Character:FindFirstChild("HumanoidRootPart")
        if root and isEnabled then
            local currentPos = root.Position
            if (currentPos - lastPosition).Magnitude < 0.2 then
                idleTime = idleTime + 1
            else
                idleTime = 0
            end
            lastPosition = currentPos
            StatusLabel.Text = "Đứng im: " .. idleTime .. "s / " .. maxIdle .. "s"
            
            if idleTime >= maxIdle then
                local hum = Character:FindFirstChildOfClass("Humanoid")
                if hum then
                    print("Thông báo: Tự động Reset nhân vật.")
                    hum.Health = 0
                end
                idleTime = 0
            end
        end
    end
end)

Player.CharacterAdded:Connect(function(newChar)
    Character = newChar
    idleTime = 0
    lastPosition = Vector3.new(0,0,0)
end)
