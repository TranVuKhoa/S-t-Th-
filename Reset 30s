-- Hàm định dạng số (2700090 -> 2,700,090)
local function formatNumber(n)
    return tostring(n):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
end

-- Cập nhật số Kill thực tế
local function updateKillDisplay()
    local stats = Player:FindFirstChild("leaderstats")
    local kills = stats and (stats:FindFirstChild("Kills") or stats:FindFirstChild("Kill"))
    if kills then
        KillLabel.Text = "KILLS: " .. formatNumber(kills.Value)
    else
        KillLabel.Text = "KILLS: N/A"
    end
end

-- Theo dõi sự thay đổi của Leaderstats
task.spawn(function()
    while true do
        updateKillDisplay()
        local stats = Player:FindFirstChild("leaderstats")
        local kills = stats and (stats:FindFirstChild("Kills") or stats:FindFirstChild("Kill"))
        if kills then
            kills.Changed:Connect(updateKillDisplay)
            break
        end
        task.wait(1)
    end
end)
