local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local LocalPlayer = Players.LocalPlayer

-- Biến kiểm soát trạng thái
local isFlinging = false
local currentTarget = nil

-- Hàm thông báo (Revert/Notify System)
local function notify(title, text)
    StarterGui:SetCore("SendNotification", {
        Title = title,
        Text = text,
        Duration = 2
    })
end

-- TẠO GIAO DIỆN MENU (GUI)
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FlingMenuGui"
screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local mainButton = Instance.new("TextButton")
mainButton.Size = UDim2.new(0, 150, 0, 50)
mainButton.Position = UDim2.new(0.05, 0, 0.4, 0) -- Vị trí bên trái màn hình
mainButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
mainButton.TextColor3 = Color3.fromRGB(255, 255, 255)
mainButton.Text = "BẬT FLING"
mainButton.Font = Enum.Font.SourceSansBold
mainButton.TextSize = 20
mainButton.Parent = screenGui

-- Bo góc cho nút
local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = UDim.new(0, 8)
uiCorner.Parent = mainButton

-- HÀM XỬ LÝ FLING
local function startFlingLoop()
    while isFlinging do
        local playerList = Players:GetPlayers()
        
        for _, target in pairs(playerList) do
            if not isFlinging then break end -- Dừng ngay nếu nhấn Tắt
            
            if target ~= LocalPlayer and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                local myChar = LocalPlayer.Character
                local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
                local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
                
                if myRoot and targetRoot then
                    notify("Flinging", "Đang áp sát: " .. target.Name)
                    
                    -- Tạo lực xoay cực mạnh
                    local bav = Instance.new("BodyAngularVelocity")
                    bav.P = 1000000
                    bav.MaxTorque = Vector3.new(1, 1, 1) * 999999
                    bav.AngularVelocity = Vector3.new(0, 9999, 0)
                    bav.Parent = myRoot
                    
                    -- Áp sát liên tục trong 1.5 giây
                    local start = tick()
                    while tick() - start < 1.5 and isFlinging do
                        RunService.Heartbeat:Wait()
                        myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 1)
                        myRoot.Velocity = Vector3.new(999, 999, 999)
                    end
                    
                    bav:Destroy() -- Reset lực xoay
                    task.wait(0.2)
                end
            end
        end
        task.wait(1) -- Nghỉ 1 giây trước khi lặp lại toàn server
    end
end

-- SỰ KIỆN CLICK NÚT
mainButton.MouseButton1Click:Connect(function()
    isFlinging = not isFlinging
    
    if isFlinging then
        mainButton.Text = "ĐANG CHẠY..."
        mainButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Đổi sang màu đỏ
        notify("Hệ thống", "Đã kích hoạt Fling toàn server!")
        startFlingLoop()
    else
        mainButton.Text = "BẬT FLING"
        mainButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40) -- Về màu gốc
        notify("Hệ thống", "Đã tắt và revert trạng thái gốc.")
    end
end)
