local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local StarterGui = game:GetService("StarterGui")

local isFlingActive = false
local flingPart = nil

-- Hàm thông báo
local function notify(title, text)
    StarterGui:SetCore("SendNotification", {
        Title = title,
        Text = text,
        Duration = 2
    })
end

-- TẠO MENU
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AuraFlingGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local btn = Instance.new("TextButton")
btn.Size = UDim2.new(0, 180, 0, 50)
btn.Position = UDim2.new(0.05, 0, 0.4, 0)
btn.Text = "AURA FLING: TẮT"
btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
btn.TextColor3 = Color3.fromRGB(255, 255, 255)
btn.Font = Enum.Font.SourceSansBold
btn.TextSize = 18
btn.Parent = screenGui
Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

-- LOGIC XỬ LÝ
local function toggleAura()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if isFlingActive then
        -- Tạo một Part riêng biệt làm Hitbox để không làm hỏng nhân vật chính
        flingPart = Instance.new("Part")
        flingPart.Name = "FlingAura"
        flingPart.Size = Vector3.new(100, 100, 100) -- Phạm vi ảnh hưởng (100 studs)
        flingPart.Transparency = 0.8 -- Bạn có thể chỉnh lên 1 để tàng hình hoàn toàn
        flingPart.CanCollide = false -- Để bạn vẫn di chuyển xuyên tường được
        flingPart.CanQuery = false
        flingPart.Massless = true
        flingPart.Color = Color3.fromRGB(255, 0, 0)
        flingPart.Parent = char

        -- Lực xoay cực đại gắn vào Part này
        local bav = Instance.new("BodyAngularVelocity")
        bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bav.AngularVelocity = Vector3.new(0, 99999, 0)
        bav.Parent = flingPart

        -- Giữ Part luôn ở vị trí của bạn
        RunService.Stepped:Connect(function()
            if isFlingActive and flingPart and root then
                flingPart.CFrame = root.CFrame
                -- Thủ thuật: Ép va chạm với người khác nhưng không ép với map
                flingPart.Velocity = Vector3.new(10000, 10000, 10000)
            end
        end)
        
        notify("Kích hoạt", "Aura Fling đang hoạt động (Bán kính 100)")
    else
        -- REVERT: Xóa bỏ mọi thứ khi tắt
        if flingPart then
            flingPart:Destroy()
            flingPart = nil
        end
        notify("Tắt", "Đã xóa Aura, nhân vật trở lại bình thường.")
    end
end

btn.MouseButton1Click:Connect(function()
    isFlingActive = not isFlingActive
    btn.Text = isFlingActive and "AURA FLING: BẬT" or "AURA FLING: TẮT"
    btn.BackgroundColor3 = isFlingActive and Color3.fromRGB(200, 50, 50) or Color3.fromRGB(40, 40, 40)
    toggleAura()
end)
